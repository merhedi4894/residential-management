# ──────────────────────────────────────
# অফিস আবাসিক ম্যানেজমেন্ট সিস্টেম - Environment Variables
# ──────────────────────────────────────

# Turso Database Connection (Production - Vercel)
# Format: libsql://your-db-name-your-org.turso.io?authToken=your-turso-auth-token
DATABASE_URL="libsql://your-db-name-your-org.turso.io?authToken=your-turso-auth-token"

# ──────────────────────────────────────
# লোকাল ডেভেলপমেন্ট এর জন্য (SQLite):
# DATABASE_URL="file:./dev.db"
# ──────────────────────────────────────
